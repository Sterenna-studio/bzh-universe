                ['1', 'rgb(0,255,0)']
            ];
            data.zmin = 0.0;
            data.zmax = 100.0;
            data.colorbar = {
                title: "winrate %"
            };
            Plotly.newPlot("d1e", [data], {
                title: "Winrate by hour<br>(excludes AI games and remakes)",
