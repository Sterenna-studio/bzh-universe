function loadJSON(path, callback, callback404) {
    fetch(path)
        .then(response => {
            if (response.status === 200) {
                return response.text().then(callback);
            } else if ((response.status === 404 || response.status === 500) && callback404 !== undefined) {
                callback404();
            }
        })
        .catch(error => {
            console.error('Error loading JSON:', error);
        });
}

